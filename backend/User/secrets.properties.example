# Copy this file to secrets.properties and fill in local values.
# secrets.properties is ignored by Git.

EVERCARE_MAIL_USERNAME=your_smtp_username
EVERCARE_MAIL_PASSWORD=your_smtp_app_password
EVERCARE_MAIL_FROM=EverCare <your_smtp_username>

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_phone_number

KEYCLOAK_CLIENT_SECRET=your_keycloak_evercare_client_secret
KEYCLOAK_FACE_CLIENT_SECRET=your_keycloak_face_client_secret
KEYCLOAK_FRONTEND_CLIENT_SECRET=your_keycloak_frontend_client_secret
