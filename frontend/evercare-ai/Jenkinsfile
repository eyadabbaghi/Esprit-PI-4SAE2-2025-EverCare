pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'badrftw/evercare-ai-frontend'
        DOCKER_REGISTRY = 'docker.io'
        SONAR_HOST_URL = 'http://10.0.2.15:9000'
        APP_DIR = 'frontend/evercare-ai'
        BRANCH_NAME = 'Badr-branch'
    }

    stages {
        stage('Checkout Git') {
            steps {
                git branch: env.BRANCH_NAME,
                    url: 'https://github.com/eyadabbaghi/Esprit-PI-4SAE2-2025-EverCare.git',
                    credentialsId: 'github-evercare'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir(env.APP_DIR) {
                    sh 'pip install -r requirements.txt'
                }
            }
        }

        stage('Test') {
            steps {
                dir(env.APP_DIR) {
                    sh 'pytest --cov=. --cov-report=xml || true'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir(env.APP_DIR) {
                    withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                            if ! command -v sonar-scanner &> /dev/null; then
                                apt-get update && apt-get install -y unzip curl
                                curl -sL https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-4.8.0.2856-linux.zip -o /tmp/sonar-scanner.zip
                                unzip -q /tmp/sonar-scanner.zip -d /opt
                                ln -sf /opt/sonar-scanner-4.8.0.2856-linux/bin/sonar-scanner /usr/local/bin/sonar-scanner
                            fi
                            sonar-scanner \
                                -Dsonar.host.url=${SONAR_HOST_URL} \
                                -Dsonar.login=${SONAR_TOKEN} \
                                -Dsonar.projectKey=evercare-ai-frontend \
                                -Dsonar.sources=. \
                                -Dsonar.python.version=3.11
                        '''
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir(env.APP_DIR) {
                    script {
                        sh "docker build -t ${DOCKER_IMAGE}:${env.BUILD_ID} -f Dockerfile ."
                        sh "docker tag ${DOCKER_IMAGE}:${env.BUILD_ID} ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }

        stage('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-evercare',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                    }
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    sh """
                        docker push ${DOCKER_IMAGE}:${env.BUILD_ID}
                        docker push ${DOCKER_IMAGE}:latest
                    """
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts 'frontend/evercare-ai/**/*'
            }
        }
    }

    post {
        always {
            sh 'docker system prune -f || true'
        }
        success {
            echo 'Build and SonarQube analysis successful!'
            mail to: 'Bader.Klila@esprit.tn,baderklila@gmail.com,tnjoker99@gmail.com, jebabli.achref@esprit.tn',
                subject: "[EverCare] AI Frontend #${env.BUILD_ID} - SUCCESS",
                body: """BUILD SUCCESSFUL - EverCare AI Frontend

Build Number: ${env.BUILD_ID}
Branch: ${env.BRANCH_NAME}

Docker Image:
- Tag: ${DOCKER_IMAGE}:${env.BUILD_ID}
- Latest: ${DOCKER_IMAGE}:latest

SonarQube: ${SONAR_HOST_URL}/dashboard?id=evercare-ai-frontend"""
        }
        failure {
            echo 'Pipeline failed!'
            mail to: 'Bader.Klila@esprit.tn,baderklila@gmail.com,tnjoker99@gmail.com',
                subject: "[EverCare] AI Frontend #${env.BUILD_ID} - FAILED",
                body: """BUILD FAILED - EverCare AI Frontend

Build: ${env.BUILD_ID}
Branch: ${env.BRANCH_NAME}

Check Jenkins logs for error details."""
        }
    }
}