pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'grafana/grafana:10.2.0'
        NAMESPACE = 'evercare'
    }

    stages {
        stage('Checkout Monitoring Config') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                    branch 'Badr-branch'
                }
            }
            steps {
                echo 'Checking out monitoring configuration from git...'
                checkout scm
            }
        }
        
        stage('Deploy Monitoring') {
            steps {
                echo 'Deploying monitoring stack...'
                
                sh 'kubectl apply -f k8s/monitoring/prometheus-configmap.yaml'
                sh 'kubectl apply -f k8s/monitoring/grafana-dashboard.yaml'
                sh 'kubectl apply -f k8s/monitoring/grafana-provisioning.yaml'
                sh 'kubectl apply -f k8s/monitoring/alertmanager-configmap.yaml'
                
                echo 'Restarting monitoring pods to pick up new config...'
                sh 'kubectl rollout restart deployment prometheus-deployment -n ${NAMESPACE} || kubectl delete pod -l app=prometheus -n ${NAMESPACE} || true'
                sh 'kubectl rollout restart deployment grafana-deployment -n ${NAMESPACE} || kubectl delete pod -l app=grafana -n ${NAMESPACE} || true'
                sh 'kubectl rollout restart deployment alertmanager-deployment -n ${NAMESPACE} || kubectl delete pod -l app=alertmanager -n ${NAMESPACE} || true'
                
                echo 'Waiting for pods to be ready...'
                sh 'sleep 30'
                
                echo 'Monitoring stack deployed successfully!'
            }
        }
        
        stage('Verify Monitoring') {
            steps {
                echo 'Verifying monitoring services...'
                sh 'kubectl get pods -n ${NAMESPACE}'
            }
        }
    }
    
    post {
        success {
            echo 'Monitoring deployment completed successfully!'
        }
        failure {
            echo 'Monitoring deployment failed!'
        }
    }
}